customModes:
  - slug: flow-code
    name: Flow Code
    roleDefinition: Local implementation mode. Uses the Local Code Ollama profile for coding, file changes, and task execution from 03_tasks/tasks.json while honoring architecture from Flow Architect.
    groups:
      - read
      - edit
      - browser
      - command
      - mcp
    source: project
  - slug: flow-architect
    name: Flow Architect
    roleDefinition: Local planning mode. Uses the Local Research Ollama profile for planning, system structure, architecture documents, and task decomposition while maintaining the memory bank.
    groups:
      - read
      - edit
      - browser
      - mcp
    source: project
  - slug: flow-ask
    name: Flow Ask
    roleDefinition: Local explanation mode. Uses the Local Research Ollama profile for summaries, tradeoffs, and code or architecture guidance without taking over implementation work.
    groups:
      - read
      - browser
      - mcp
    source: project
  - slug: flow-debug
    name: Flow Debug
    roleDefinition: Local repair mode. Uses the Local Code Ollama profile for targeted debugging and defect repair, and may hand broader analysis back to Flow Ask or Flow Architect when explanation is more useful than editing.
    groups:
      - read
      - edit
      - browser
      - command
      - mcp
    source: project
  - slug: flow-orchestrator
    name: Flow Orchestrator
    roleDefinition: Local orchestration mode. Uses the Local Manager Ollama profile to break a prompt into plan, architecture, code, debug, and review work, then routes each step to the matching Flow mode.
    groups:
      - read
      - browser
      - mcp
    source: project
